---
import Layout from '../../layouts/Layout.astro';
import Issues from '../../components/Issues.astro';
import content from '../../lib/contents/pages.json';

const options = content.about.options;
---
<Layout title="OSRV - Quem somos">
  <section class="flex flex-col md:flex-row items-start gap-8 max-w-5xl mx-auto mb-20">
    <!-- Images -->
    <div class="flex flex-col gap-6 md:w-1/2 anim-left pt-4">
      <img
        src="/images/about_children.jpeg"
        alt="Crianças em atividade com tecnologia"
        class="w-full h-56 rounded-2xl object-cover"
        loading="eager"
      />
      <img
        src="/images/about_children-02.jpeg"
        alt="Crianças em atividade"
        class="w-full h-56 rounded-2xl object-cover"
        loading="lazy"
      />
      <img
        src="/images/about_children-03.jpeg"
        alt="Crianças em atividade"
        class="w-full h-56 rounded-2xl object-cover"
        loading="lazy"
      />
    </div>

    <!-- Text -->
    <div class="md:w-1/2 anim-right space-y-4">
      {options.map((opt) => (
        <article class="py-4 border-b border-gray-200 last:border-0">
          <h2 class="text-xl font-semibold text-gray-800 mb-2">{opt.question}</h2>
          <p class="text-gray-600 leading-relaxed text-sm">{opt.answer}</p>
        </article>
      ))}
    </div>
  </section>

  <!-- Services -->
  <section data-inview>
    <Issues />
  </section>
</Layout>
