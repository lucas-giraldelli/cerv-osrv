---
const contact = {
  title: 'Nosso endereço e contato',
  text:  'Endereço: Rua Nova Mutum, quadra 31 lote 8 - Jardim Renascer, Cuiabá - MT, 78061-360',
  text2: 'Telefone: (65) 99649-3092',
};
---
<footer class="bg-dark text-white py-12">
  <div class="flex flex-col items-center gap-6 px-4">
    <h2 class="text-7xl font-bold tracking-wide">OSRV</h2>

    <ul class="flex flex-wrap justify-center gap-6 list-none m-0 p-0">
      <li>
        <a href="/transparencia" class="text-white no-underline hover:text-accent transition-colors text-sm">
          Transparência
        </a>
      </li>
      <li>
        <button
          class="bg-transparent text-white border-none text-sm hover:text-accent transition-colors p-0"
          data-modal
          data-modal-title={contact.title}
          data-modal-text={contact.text}
          data-modal-text2={contact.text2}
        >
          Endereço e Contato
        </button>
      </li>
    </ul>

    <ul class="flex gap-4 list-none m-0 p-0">
      <li>
        <a href="https://www.facebook.com/osrafaelverlangieri/" target="_blank" rel="noopener noreferrer" aria-label="Facebook" class="block hover:opacity-80 transition-opacity">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="20" cy="20" r="20" fill="#1d2d50"/>
            <path d="M23 12h-2.5A4.5 4.5 0 0 0 16 16.5V19h-2v4h2v8h4v-8h3l.5-4H20v-2.5A.5.5 0 0 1 20.5 16H23v-4z" fill="white"/>
          </svg>
        </a>
      </li>
      <li>
        <a href="https://www.instagram.com/osrafaelverlangieri/" target="_blank" rel="noopener noreferrer" aria-label="Instagram" class="block hover:opacity-80 transition-opacity">
          <svg width="40" height="40" viewBox="0 0 40 40" fill="none" xmlns="http://www.w3.org/2000/svg">
            <circle cx="20" cy="20" r="20" fill="#1d2d50"/>
            <rect x="11" y="11" width="18" height="18" rx="5" stroke="white" stroke-width="2" fill="none"/>
            <circle cx="20" cy="20" r="4.5" stroke="white" stroke-width="2" fill="none"/>
            <circle cx="25.5" cy="14.5" r="1.2" fill="white"/>
          </svg>
        </a>
      </li>
    </ul>

    <p class="text-xs text-gray-500 mt-2">
      © {new Date().getFullYear()} OSRV — Obras Sociais Rafael Verlangieri
    </p>
  </div>
</footer>
