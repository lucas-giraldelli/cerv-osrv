---
import comp from '../lib/contents/components.json';
const issues = comp.issues;
---
<section class="max-w-6xl mx-auto px-4 py-8 pb-20">
  <div class="text-center mb-12">
    <h2 class="text-4xl font-bold mb-4">Serviços prestados</h2>
    <p class="max-w-2xl mx-auto text-base text-gray-600 leading-relaxed">
      Buscamos alcançar melhores resultados e um desenvolvimento sustentável que nos permita
      proporcionar uma melhor qualidade de vida à comunidade do Bairro Jardim Renascer e
      arredores, em Cuiabá – MT, ofertando atividades como: Alfabetização e letramento
      matemático, xadrez, judô, esportes radicais e trabalhos manuais e artesanais.
    </p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6 justify-items-center">
    {issues.map((issue) => (
      <div class="bg-white rounded-lg shadow-md p-8 flex flex-col items-center w-full max-w-[15rem]">
        <div class="w-20 h-20 mb-6 flex items-center justify-center">
          <img src={issue.icon} alt={issue.title} class="w-16 h-16" />
        </div>
        <h3 class="text-lg font-semibold text-center mb-3">{issue.title}</h3>
        <p class="text-sm text-gray-600 text-center mb-6 leading-relaxed flex-1">
          {issue.description}
        </p>
        <button
          class="px-4 py-2 bg-accent rounded-lg font-bold text-sm hover:bg-yellow-400 transition-colors"
          data-modal
          data-modal-title={issue.title}
          data-modal-text={issue.text}
        >
          Leia mais
        </button>
      </div>
    ))}
  </div>
</section>
